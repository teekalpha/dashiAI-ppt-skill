{
  "name": "dashiai-ppt",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:update": "node scripts/update-project-docs.mjs",
    "render:deck": "tsx scripts/render-deck.jsx",
    "render:goal": "tsx scripts/render-goal-deck.jsx",
    "render:themes": "tsx scripts/render-deck.jsx examples/component-decks/all-themes-showcase.jsx output/theme-preview/ppt/index.html",
    "preview:https": "node scripts/serve-preview-https.mjs",
    "preview:start": "node scripts/start-preview-server.mjs",
    "showcase:update": "node scripts/validate-layout-showcase.mjs && npm run render:themes && npm run validate:swiss -- output/theme-preview/ppt/index.html",
    "themes:import": "tsx scripts/import-claude-themes.jsx",
    "metadata:update": "node scripts/update-generated-metadata.mjs",
    "manifest:update": "tsx scripts/update-layout-manifest.jsx",
    "skill:sync": "node scripts/sync-skill.mjs",
    "layout:query": "node scripts/layout-query.mjs",
    "inspect:layout": "node scripts/inspect-layout.mjs",
    "media:stage": "node scripts/stage-media.mjs",
    "props:safe": "node scripts/write-safe-props.mjs",
    "validate:goal-spec": "node scripts/validate-goal-spec.mjs",
    "validate:skill-workflow-tools": "node scripts/validate-skill-workflow-tools.mjs",
    "validate:control-naming": "node scripts/validate-control-naming.mjs",
    "validate:skill-media-workflow": "node scripts/validate-skill-media-workflow.mjs",
    "validate:swiss": "node scripts/validate-swiss-deck.mjs",
    "validate:pdf-export": "node scripts/validate-pdf-export.mjs",
    "validate:editor-presenter-modes": "npm run render:themes && node scripts/validate-editor-presenter-modes.mjs",
    "validate:editor-presenter-modes:only": "node scripts/validate-editor-presenter-modes.mjs",
    "validate:editor-ui-polish": "npm run render:themes && node scripts/validate-editor-ui-polish.mjs",
    "validate:editor-ui-polish:only": "node scripts/validate-editor-ui-polish.mjs",
    "validate:page-transitions": "npm run render:themes && node scripts/validate-page-transitions.mjs",
    "validate:page-transitions:only": "node scripts/validate-page-transitions.mjs",
    "validate:url-state": "npm run render:themes && node scripts/validate-url-state.mjs",
    "validate:url-state:only": "node scripts/validate-url-state.mjs",
    "validate:dynamic-page-numbers": "node scripts/validate-dynamic-page-numbers.mjs",
    "validate:overview-performance": "npm run render:themes && node scripts/validate-overview-performance.mjs",
    "validate:overview-performance:only": "node scripts/validate-overview-performance.mjs",
    "validate:goal-copy": "node scripts/validate-goal-copy.mjs",
    "validate:theme-display-names": "node scripts/validate-theme-display-names.mjs",
    "validate:skill-name": "node scripts/validate-skill-name.mjs",
    "test": "npm run validate:control-naming && npm run render:themes && npm run validate:swiss -- output/theme-preview/ppt/index.html"
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "html-to-image": "^1.11.13",
    "pptxgenjs": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.177.0"
  },
  "devDependencies": {
    "pdf-lib": "^1.17.1",
    "playwright-core": "^1.60.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.20.0"
  }
}
